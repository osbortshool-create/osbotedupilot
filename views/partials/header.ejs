    <style>
        /* Enhanced Admin Layout Fixes */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: calc(100vh - var(--navbar-height));
        }

        .page-content,
        .dashboard,
        .student-portal {
            flex: 1;
            padding-bottom: 2rem;
        }

        /* Clean header logo styling */
        .nav-brand {
            display: flex;
            align-items: center;
            padding: 0.25rem 0.5rem;
            cursor: pointer;
        }

        @media (max-width: 768px) {
            .nav-logo {
                width: 42px;
                height: 42px;
            }
        }
        @keyframes badgeShine {
            0% { left: -100%; }
            50% { left: 100%; }
            100% { left: 100%; }
        }

        /* Enhanced hover effects */
        .nav-brand:hover {
            transform: scale(1.05);
        }

        .nav-brand:hover .brand-icon-glow {
            animation-duration: 1s;
        }

        .nav-brand:hover .brand-icon {
            animation-duration: 0.5s;
            transform: rotate(360deg);
        }

        .nav-brand:hover .ng-badge {
            animation-duration: 0.5s;
        }

        /* Footer positioning fix */
        .footer {
            margin-top: auto;
            width: 100%;
            margin-left: 0;
            transition: all 0.3s ease;
        }

        @media (min-width: 769px) {
            body.with-sidebar .footer {
                margin-left: var(--sidebar-width);
                width: calc(100% - var(--sidebar-width));
            }
            
            body.sidebar-closed .footer {
                margin-left: 0;
                width: 100%;
            }
        }

        /* Ensure proper spacing */
        .dashboard-content,
        .portal-content {
            margin-bottom: 2rem;
        }

        /* Fix overlapping issues */
        .table-container,
        .form-container,
        .dashboard-section {
            margin-bottom: 2rem;
            position: relative;
            z-index: 1;
        }

        /* Responsive improvements */
        @media (max-width: 768px) {
            .nav-brand {
                font-size: 1rem;
                gap: 0.5rem;
            }
            
            .brand-icon {
                font-size: 1.4rem;
            }
            
            .brand-text {
                font-size: 0.9rem;
            }
            
            .ng-badge {
                font-size: 0.6rem;
                padding: 2px 5px;
            }
        }
    </style>
</head>
<body class="with-sidebar">
  
    <% if (locals.user) { %>
       <!-- TOP NAV -->
<nav class="navbar">
  <div class="nav-container">
   <div class="nav-brand" id="navBrand">
      <img src="https://i.imgur.com/NiDDWOx.png" style="height: 50px !important; width: 150px !important;" alt="EduPilot Logo" class="nav-logo">
    </div>

    <div class="nav-controls">
      <!-- Notification Dropdown -->
      <div class="notification-container">
        <button class="notification-btn" id="notificationBtn">
          <i class="fas fa-bell"></i>
          <% if (locals.unreadCount && locals.unreadCount > 0) { %>
            <span class="notification-badge" id="notificationBadge"><%= locals.unreadCount > 99 ? '99+' : locals.unreadCount %></span>
          <% } %>
        </button>
        <div class="notification-dropdown" id="notificationDropdown">
          <div class="notification-header">
            <h4>Notifications</h4>
          </div>
          <div class="notification-list">
            <% if (locals.user && (locals.user.role === 'admin' || locals.user.role === 'teacher' || locals.user.role === 'officer')) { %>
              <% const lastLogin = locals.notificationData && locals.notificationData.lastLogin ? new Date(locals.notificationData.lastLogin) : null; %>
              <div class="notification-item">
                <div class="notification-icon">
                  <i class="fas fa-user"></i>
                </div>
                <div class="notification-content">
                  <p><strong>Last Login:</strong> <%= lastLogin ? lastLogin.toLocaleString() : 'Not available' %></p>
                  <small><%= lastLogin ? Math.floor((Date.now() - lastLogin) / (1000 * 60 * 60 * 24)) + ' days ago' : '' %></small>
                </div>
              </div>
              <% if (locals.notificationData && locals.notificationData.activities && Array.isArray(locals.notificationData.activities) && locals.notificationData.activities.length > 0) { %>
                <% locals.notificationData.activities.forEach(activity => { %>
                  <div class="notification-item">
                    <div class="notification-icon">
                      <i class="fas fa-edit"></i>
                    </div>
                    <div class="notification-content">
                      <p><strong>Recent Activity:</strong> <%= activity.message %></p>
                      <small><%= activity.time ? new Date(activity.time).toLocaleString() : 'Unknown time' %></small>
                    </div>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="notification-item">
                  <div class="notification-icon">
                    <i class="fas fa-info-circle"></i>
                  </div>
                  <div class="notification-content">
                    <p><strong>No new notifications</strong></p>
                    <small>You're all caught up</small>
                  </div>
                </div>
              <% } %>
            <% } else if (locals.user && locals.user.role === 'student') { %>
              <% if (locals.notificationData && locals.notificationData.activities && Array.isArray(locals.notificationData.activities) && locals.notificationData.activities.length > 0) { %>
                <% locals.notificationData.activities.forEach(activity => { %>
                  <div class="notification-item">
                    <div class="notification-icon">
                      <i class="fas fa-bullhorn"></i>
                    </div>
                    <div class="notification-content">
                      <p><strong>Announcement:</strong> <%= activity.message %></p>
                      <small><%= activity.time ? new Date(activity.time).toLocaleString() : 'Unknown time' %></small>
                    </div>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="notification-item">
                  <div class="notification-icon">
                    <i class="fas fa-info-circle"></i>
                  </div>
                  <div class="notification-content">
                    <p><strong>No new announcements</strong></p>
                    <small>You're all caught up</small>
                  </div>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>

      <button class="sidebar-toggle sidebar-toggle-btn"  id="sidebarToggle">
        <i class="fas fa-bars"></i>
      </button>

      <% if (locals.campus) { %>
      <span class="campus-badge" style="background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; margin-left: 8px; display: inline-flex; align-items: center; gap: 6px;">
        <i class="fas fa-school"></i> <%= campus %> Campus
      </span>
      <% } %>

      <!-- Desktop-only user display -->
      <div class="nav-user desktop-only">
        <span class="user-name">
          <i class="fas fa-user-circle"></i> <%= user.name %>
        </span>
        <a href="#" class="logout-btn" onclick="showLogoutModal(event)">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </div>
    </div>
  </div>
</nav>

