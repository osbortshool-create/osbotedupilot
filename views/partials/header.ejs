                    <% } %>

    <!-- Mobile-only user display -->
    <div class="nav-user mobile-only">
      <hr>
      <span class="user-name">
        <i class="fas fa-user-circle"></i> <%= user.name %>
      </span>
      <a href="#" class="logout-btn" onclick="showLogoutModal(event)">
