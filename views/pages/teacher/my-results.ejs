<%- include('../../partials/header') %>
<div style="padding:2rem">
  <h1>My Results</h1>
  <% if (results && results.length > 0) { %>
    <table border="1" cellpadding="8">
      <thead><tr><th>Student</th><th>Subject</th><th>Class</th><th>Total</th><th>Grade</th></tr></thead>
      <tbody>
        <% results.forEach(r => { %>
          <tr>
            <td><%= r.studentName %></td>
            <td><%= r.subject %></td>
            <td><%= r.className %></td>
            <td><%= r.total %></td>
            <td><%= r.grade %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No results found.</p>
  <% } %>
</div>
<%- include('../../partials/footer') %>
